# GRANDPA_JOE Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Racing Data API Keys (optional - for data ingestion from providers)
# =============================================================================
EQUIBASE_API_KEY=
DRF_API_KEY=

# =============================================================================
# NEXUS Bridge to ALFRED (optional - enables cross-brain learning)
# =============================================================================
ALFRED_URL=http://127.0.0.1:8000
NEXUS_SECRET=your-shared-secret-here
NEXUS_ENABLED=true

# =============================================================================
# Responsible Gambling Limits
# =============================================================================
DAILY_LOSS_LIMIT=100.00
MAX_SINGLE_BET=50.00
SESSION_TIME_LIMIT=120

# =============================================================================
# Server Settings
# =============================================================================
GRANDPA_JOE_HOST=127.0.0.1
GRANDPA_JOE_PORT=8100
GRANDPA_JOE_DEBUG=false

# =============================================================================
# Custom data directory (optional - defaults to C:/Drive/data/grandpa_joe)
# =============================================================================
# GRANDPA_JOE_HOME=C:/custom/path
